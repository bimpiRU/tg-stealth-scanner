# Telegram bot token from @BotFather
BOT_TOKEN=твой_токен_из_BotFather

# Your Telegram user ID (numeric). Get it from @userinfobot
ADMIN_ID=your_telegram_user_id

# Optional extra check: your Telegram username without @
ADMIN_USERNAME=

# Bot language: en or ru
DEFAULT_LANG=ru

# Rate limits
RATE_LIMIT_SECONDS=10
RATE_LIMIT_BURST=10
RATE_LIMIT_WINDOW=60

# Optional: AI summarization (OpenAI-compatible API)
AI_API_KEY=
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini
AI_MAX_TOKENS=800

# Optional: proxy for HTTP(S) recon (does not apply to raw nmap/scapy packets)
PROXY_URL=
PROXY_TYPE=http
EVADE_MIN_DELAY=0.5
EVADE_MAX_DELAY=2.0

# Timeouts in seconds
SCAN_TIMEOUT=180
OSINT_TIMEOUT=120

# Allow scanning private/RFC1918 IPs (172.16.x.x, 192.168.x.x, 10.x.x.x).
# Only enable on your own network.
ALLOW_PRIVATE_IPS=false

# Directories inside container
RESULTS_DIR=/app/results
LOGS_DIR=/app/logs

# Local Ollama / DeepSeek AI backend
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=deepseek-r1:7b
OLLAMA_TIMEOUT=120

# Agent loop limits
AGENT_MAX_ITERATIONS=5

# SQLite database path inside container
DB_PATH=/app/data/osint.db
